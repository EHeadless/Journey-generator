{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": false,
    "noEmit": false,
    "outDir": "../.dist",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["./**/*.ts"]
}
